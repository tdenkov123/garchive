GRPC_PORT=50051
APP_ENV=development
GRPC_INSECURE=true
GRPC_ENABLE_REFLECTION=true

POSTGRES_DSN=postgres://fms:fms@localhost:5432/fms?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=5m

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=files
MINIO_USE_SSL=false
PRESIGN_TTL=15m
MULTIPART_PART_SIZE=5242880
MAX_FILE_SIZE_BYTES=5368709120

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=file.events

# Auth (optional)
JWT_ENABLED=false
JWT_HMAC_SECRET=change-me-in-production
JWT_ISSUER=garchive
JWT_AUDIENCE=garchive-api

# TLS (required when GRPC_INSECURE=false)
# GRPC_TLS_CERT=/path/to/cert.pem
# GRPC_TLS_KEY=/path/to/key.pem

RATE_LIMIT_RPS=50
METRICS_PORT=9090
SHUTDOWN_TIMEOUT=15s
